# Root .env — consumed by docker-compose interpolation only.
# Each app also has its own .env (see backend/.env.example, frontend/.env.example).

# Postgres credentials (used by the postgres service and composed into DATABASE_URL)
POSTGRES_USER=accountio
POSTGRES_PASSWORD=accountio
POSTGRES_DB=accountio

# Anthropic API key — copy from anthropic_api_key.txt
ANTHROPIC_API_KEY=sk-ant-...
