{
  "name": "accountio",
  "version": "0.0.0",
  "private": true,
  "description": "Invoice-to-journal-entry web app (take-home).",
  "scripts": {
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "bun scripts/typecheck.ts",
    "test": "cd backend && bun test",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.10"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json,jsonc}": "biome check --write --no-errors-on-unmatched"
  },
  "trustedDependencies": ["@biomejs/biome"]
}
