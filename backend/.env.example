# Backend .env — copy to backend/.env and fill in.
# Defaults assume Postgres on localhost:5432 (running via `docker compose up -d postgres`).

DATABASE_URL=postgres://accountio:accountio@localhost:5432/accountio

# Anthropic — copy from anthropic_api_key.txt
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6

# HTTP
PORT=3001
HOST=0.0.0.0

# Where uploaded PDFs land (relative to backend/ when running locally, /app/uploads in docker).
UPLOAD_DIR=./uploads

# Optional: comma-separated origins for CORS. Leave unset to disable CORS entirely
# (default — the browser only talks to the Next.js origin via rewrites).
# CORS_ORIGIN=http://localhost:3000
